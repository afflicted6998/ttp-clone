{
  "name": "ttp-clone",
  "private": true,
  "type": "module",
  "description": "Outside Feet Phase 1 PWA (root Vite app) + dev dependencies for testing Supabase edge function logic locally. Edge functions run on Deno; supabase/functions/*/deno.json maps the same package names for deploy.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "tsx supabase/functions/traccar-receiver/ping.test.ts && tsx supabase/functions/ics-ingest/parse.test.ts && tsx src/mediaPath.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "ical.js": "^2.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
