# Copy to .env for local dev; set the same two variables in Vercel for deploys.
# Both values are in Supabase Dashboard -> Settings -> API.
# The anon key is the PUBLISHABLE key — safe in the browser (RLS is the guard).
# NEVER put the service_role key here or anywhere in this repo.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
